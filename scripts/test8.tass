//
gvar rectX = 10
gvar rectDx
gvar count
do {
    fill(3500)
    stroke(3500)
    clear()
    fill(256)
    stroke(256)
    rectDx = rectX
    rectDx += 10
    count = 0
    do {
        lvar rtop = count
        rtop *= 12

        drect(rectX,rectDx,rtop)
        count ++
    } while( count < 5)

    rectX ++
    rectX %= 53
    update()
} while (0 == 0)

function drect(left, right, top){
    lvar bottom  = top
    bottom += 10
    rect(left, top,right,bottom)
}